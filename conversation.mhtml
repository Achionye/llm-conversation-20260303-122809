<span class="line"><span style="color:#24292E"> d </span><span style="color:#D73A49">=</span><span style="color:#24292E"> re.sub(</span><span style="color:#D73A49">r</span><span style="color:#032F62">"</span><span style="color:#22863A;font-weight:bold">\.</span><span style="color:#032F62">pdf</span><span style="color:#005CC5">$</span><span style="color:#032F62">"</span><span style="color:#24292E">, </span><span style="color:#032F62">""</span><span style="color:#24292E">, d)</span></span>
