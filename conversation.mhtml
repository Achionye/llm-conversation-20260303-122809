eight="16" stroke-width="1.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="currentColor" class="absolute inset-0 m-auto opacity-100 transition-opacity duration-300"><path d="M19.4 20H9.6C9.26863 20 9 19.7314 9 19.4V9.6C9 9.26863 9.26863 9 9.6 9H19.4C19.7314 9 20 9.26863 20 9.6V19.4C20 19.7314 19.7314 20 19.4 20Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path><path d="M15 9V4.6C15 4.26863 14.7314 4 14.4 4H4.6C4.26863 4 4 4.26863 4 4.6V14.4C4 14.7314 4.26863 15 4.6 15H9" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg></button></div><div class="code-block_container__lbMX4"><pre class="shiki github-light shiki-code-block" style="background-color:#fff;color:#24292e" tabindex="0"><code class="whitespace-pre-wrap break-words"><span class="line"><span>cd C:\Users\VISITOR\Documents\journal\oguta_review_project</span></span>
<span class="line"><span></span></span>
<span class="line"><span>$dst = ".\forlitrev_pdfs"</span></span>
