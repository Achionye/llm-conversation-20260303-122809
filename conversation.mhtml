<span class="line"><span>      keep_path = $keep.Path</span></span>
<span class="line"><span>      drop_path = $d.Path</span></span>
<span class="line"><span>      size = $keep.Size</span></span>
<span class="line"><span>    }</span></span>
<span class="line"><span>  }</span></span>
<span class="line"><span>}</span></span>
<span class="line"><span></span></span>
